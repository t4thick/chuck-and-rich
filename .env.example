# --- Copy values into .env.local (dev) and Vercel → Project → Settings → Environment Variables (production) ---

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postmark (order receipt + merchant alert) — https://postmarkapp.com/
# Orders work without this; emails are skipped if POSTMARK_SERVER_TOKEN is empty.
POSTMARK_SERVER_TOKEN=
# Must be a sender signature / verified domain in Postmark
EMAIL_FROM="Lovely Queen African Market <orders@your-domain.com>"
MERCHANT_ORDER_EMAIL=
# Optional (default: outbound)
# POSTMARK_MESSAGE_STREAM=outbound

# Public site URL — no trailing slash. Set on Vercel to your production domain (e.g. https://your-app.vercel.app).
# Required for Supabase email links (password reset, magic link, signup) so redirects never point at localhost.
NEXT_PUBLIC_SITE_URL=

# Stripe — test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Publishable key (pk_test_…) — required for embedded card form (Payment Element) in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook must receive checkout.session.completed (hosted Checkout) and payment_intent.succeeded (embedded checkout)

# Optional: show "Continue with Google" on login/signup. Set to 1 after enabling Google in Supabase → Authentication → Providers.
# NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=1

# Legacy admin cookie (optional). If set, must match cookie from POST /api/admin/login for admin UI + API access.
# Prefer Supabase users with profiles.role = admin.
# ADMIN_PASSWORD=
# SUPABASE_DB_PASSWORD=
