# --- Copy values into .env.local (dev) and Vercel → Project → Settings → Environment Variables (production) ---

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postmark (order receipt + merchant alert) — https://postmarkapp.com/
# Orders work without this; emails are skipped if POSTMARK_SERVER_TOKEN is empty.
POSTMARK_SERVER_TOKEN=
# Must be a sender signature / verified domain in Postmark
EMAIL_FROM="Lovely Queen African Market <orders@your-domain.com>"
MERCHANT_ORDER_EMAIL=
# Optional (default: outbound)
# POSTMARK_MESSAGE_STREAM=outbound

# Canonical site URL for links inside emails (track order, admin). Optional on Vercel — VERCEL_URL is used as fallback.
NEXT_PUBLIC_SITE_URL=

# Stripe (Checkout + webhooks) — test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional until you add Elements: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Other (if you use them)
# ADMIN_PASSWORD=
# SUPABASE_DB_PASSWORD=
